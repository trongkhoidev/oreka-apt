# PostgreSQL Database
PG_URL=postgres://user:password@localhost:5432/oreka

# Aptos Indexer - MAINNET
APTOS_INDEXER=https://indexer.mainnet.aptoslabs.com/v1/graphql
# For testnet: https://indexer-testnet.staging.gcp.aptosdev.com/v1/graphql

# Module Configuration - MAINNET
MODULE_ADDR=0x288411cf0c7d7fe21fde828a8958f1971934dd9237fb69be36e15470b857449d
MODULE_NAME=market_core_v2

# Indexer Settings
BATCH_SIZE=1000
POLL_INTERVAL_MS=1500
MAX_RETRIES=3
RETRY_DELAY_MS=2000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Timezone for snapshots
TIMEZONE=Asia/Ho_Chi_Minh
